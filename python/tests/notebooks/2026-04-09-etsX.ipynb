   "source": [
    "import numpy as np\n",
    "import pandas as pd\n",
    "\n",
    "from smooth import ADAM\n",
    "\n",
    "df = pd.read_csv(\"../data/etsx_data.csv\")\n",
    "\n",
    "y = df[\"y\"]\n",
    "X = df[[\"x1\", \"x2\"]]\n",
    "\n",
    "model = ADAM(model=\"AAN\", regressors=\"use\", h=5, holdout=True)\n",
    "model.fit(y, X)\n",
    "\n",
    "\n",
    "print(model.summary())\n",
    "\n",
    "model.predict(5, X.tail(5))\n"
   ]
  }
